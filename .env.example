# OpenAI API
# 실제 키는 `.env` 파일에만 넣고, 이 파일은 플레이스홀더만 유지한다 (git 추적 대상).
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# Semantic Scholar (선택). 없으면 익명 호출
SEMANTIC_SCHOLAR_API_KEY=

# OpenAlex polite pool 참여용 이메일 (선택 권장)
OPENALEX_MAILTO=

# 세션 JSON 저장 디렉토리
SESSIONS_DIR=data/sessions

# 로그 레벨: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# HTTP 요청 타임아웃(초)
REQUEST_TIMEOUT_SECONDS=20.0

# 검색 재시도 상한 (모두 거부 시 쿼리 재생성 횟수)
MAX_RETRY_LOOPS=3
